#include <stdio.h>

#define TAMANHO_TABULEIRO 8  // Definindo o tamanho do tabuleiro como 8x8

void exibirTabuleiro(char tabuleiro[TAMANHO_TABULEIRO][TAMANHO_TABULEIRO]) 

{
    printf("\nTabuleiro Atual:\n");

    for (int i = 0; i < TAMANHO_TABULEIRO; i++)
    
    { 
        for (int j = 0; j < TAMANHO_TABULEIRO; j++) 
       
        {  
            printf("%c ", tabuleiro[i][j]);  // Exibe a peça ou espaço vazio
        }

        printf("\n");  // Pula para a próxima linha do tabuleiro
    }
}

void moverTorre(char tabuleiro[TAMANHO_TABULEIRO][TAMANHO_TABULEIRO], int linha)

{
    int colunaTorre = -1;
    // Procura a Torre na Linha escolhida
    for (int j = 0; j < TAMANHO_TABULEIRO; j++) 
    
    {
        if (tabuleiro[linha][j] == 'T') 
        
        {  
            colunaTorre = j;  // Salva a posição da Torre
            break;
        }
    }

    if (colunaTorre != -1) 
    
    {  
        tabuleiro[linha][colunaTorre] = '.';  // Remove a Torre do local atual
        for (int i = 1; i <= 5; i++)
        
        {  
            if (colunaTorre + i < TAMANHO_TABULEIRO) 
            
            {  
                // Verifica se está dentro do tabuleiro
                tabuleiro[linha][colunaTorre + i] = 'T';  // Move a Torre
            } 
            
            else 
            
            {
                break;  // Se ultrapassar o limite do tabuleiro, interrompe o movimento
            }
        }
    }
}

void moverBispo(char tabuleiro[TAMANHO_TABULEIRO][TAMANHO_TABULEIRO], int linha, int coluna)

{
    int i = 1;

    while (i <= 5) 
    
    {  
        // Limita o movimento a 5 casas
        if (linha - i >= 0 && coluna + i < TAMANHO_TABULEIRO)
        
        {  
            // Verifica os limites do tabuleiro
            tabuleiro[linha][coluna] = '.';  // Remove o Bispo do local atual
            linha--;  // Move o Bispo para cima
            coluna++;  // Move o Bispo para a direita
            tabuleiro[linha][coluna] = 'B';  // Coloca o Bispo no novo local

            printf("Cima, Direita\n");

        } 
        
        else 
        
        {
            printf("Movimento fora dos limites do tabuleiro.\n");  // Informa quando o movimento está fora do limite
            break;
        }

        i++;  // Incrementa o contador
    }
}

void moverRainha(char tabuleiro[TAMANHO_TABULEIRO][TAMANHO_TABULEIRO], int linha, int coluna) {
    int i = 1;

    do
    
    {
        if (coluna - i >= 0) 
        
        {  
            // Verifica se o movimento está dentro do tabuleiro
            tabuleiro[linha][coluna] = '.';  // Remove a Rainha do local atual
            coluna--;  // Move a Rainha para a esquerda
            tabuleiro[linha][coluna] = 'R';  // Coloca a Rainha no novo local
            printf("Esquerda\n");
        } 
        
        else 
        
        {
            printf("Movimento fora dos limites do tabuleiro.\n");  // Informa quando o movimento está fora do limite
            break;
        }

        i++;  // Incrementa o contador

    } 
    
    while (i <= 8);  // Limita o movimento da Rainha
}

